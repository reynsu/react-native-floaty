{
  "name": "react-native-floaty",
  "version": "0.1.0",
  "description": "Mobile-first floating action toolbar for React Native. Animated, dismiss-on-outside-tap, themable via tokens. Zero animation/gesture dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "react-native",
    "floating",
    "action",
    "bar",
    "fab",
    "toolbar",
    "mobile",
    "popover",
    "headless",
    "lightweight",
    "zero-dependencies",
    "ios",
    "android",
    "expo"
  ],
  "license": "MIT",
  "author": "reynsu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reynsu/react-native-floaty.git"
  },
  "bugs": {
    "url": "https://github.com/reynsu/react-native-floaty/issues"
  },
  "homepage": "https://github.com/reynsu/react-native-floaty#readme",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.74.87",
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-test-renderer": "18.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
