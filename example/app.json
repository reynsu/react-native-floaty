{
  "expo": {
    "name": "react-native-floaty",
    "slug": "react-native-floaty-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.reynsu.reactnativefloatyexample",
      "supportsTablet": true
    },
    "android": {
      "package": "com.reynsu.reactnativefloatyexample",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "052be0e4-b119-45f0-ac1d-d3b4210f2b96"
      }
    },
    "owner": "reynsu"
  }
}
